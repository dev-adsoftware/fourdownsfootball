>\n        <TextInput\n          // label=\"Username\"\n          // mode=\"flat\"\n          autoCapitalize=\"none\"\n          returnKeyType=\"next\"\n          value={username}\n          onChangeText={(text: string) => setUsername(text)}\n        />\n        <TextInput\n          // label=\"Password\"\n          // mode=\"flat\"\n          autoCapitalize=\"none\"\n          returnKeyType=\"done\"\n          value={password}\n          onChangeText={(text: string) => setPassword(text)}\n          secureTextEntry\n        />\n        {/* <HelperText type=\"error\" visible={error.length > 0}>\n          Error: {error}\n        </HelperText> */}\n        <Button\n          // mode=\"contained\"\n          title=\"Sign Up\"\n          onPress={async () => {\n            if (username.length === 0 || password.length === 0) {\n              console.log('me');\n              // setError('Username and password are required.');\n            } else {\n              try {\n                await Auth.signIn(username, password);\n                auth.setUser({ username: username });\n                navigation.reset({ index: 0, routes: [{ name: 'SignIn' }] });\n              } catch (e) {\n                console.error(e);\n                // setError(e.message);\n              }\n            }\n          }}\n        />\n        {/* Sign Up\n        </Button> */}\n        {/* <Input />\n        <PrimaryButton\n          text=\"Sign in\"\n          onPress={async () => {\n            try {\n              await Auth.signIn('kgorges', 'Fourdowns!3058');\n              auth.setUser({ username: 'kgorges' });\n            } catch (e) {\n              console.error(e);\n            }\n          }}\n        />\n        <SecondaryButton\n          text=\"Sign up\"\n          onPress={async () => {\n            try {\n              await Auth.signIn('kgorges', 'Fourdowns!3058');\n              auth.setUser({ username: 'kgorges' });\n            } catch (e) {\n              console.error(e);\n            }\n          }}\n        /> */}\n      </View>\n    </>\n  );\n};\n\nconst styles = StyleSheet.create({\n  container: {\n    flex: 1,\n    alignItems: 'center',\n    justifyContent: 'center',\n    backgroundColor: 'white',\n  },\n});\n","/Users/gorgesk/OneDrive - kochind.com/github/fourdownsfootball/src/screens/auth/signin/index.tsx",["55","56","57","58"],"import React from 'react';\nimport { View, StyleSheet, Image, TextInput, Button } from 'react-native';\n// import { Button, TextInput } from 'react-native-paper';\nimport { Auth } from 'aws-amplify';\nimport { useAuth } from '../../../providers/auth';\n/* eslint-disable-next-line */\nimport { StackNavigationProp } from '@react-navigation/stack';\nimport backgroundImage from '../../../background.jpg';\n\ninterface AuthSignInScreenProps {\n  navigation: StackNavigationProp<{ SignUp: undefined }>;\n}\n\nexport default ({ navigation }: AuthSignInScreenProps) => {\n  const [username, setUsername] = React.useState('');\n  const [password, setPassword] = React.useState('');\n  // const [setError] = React.useState('');\n\n  const auth = useAuth();\n\n  console.log({ backgroundImage: backgroundImage });\n\n  return (\n    <>\n      <View style={styles.container}>\n        <Image\n          source={require('../../../background.jpg')}\n          style={{\n            height: 400,\n            width: 400,\n            // transform: [{ scaleX: I18nManager.isRTL ? -1 : 1 }],\n          }}\n        />\n        <TextInput\n          style={{ width: 340 }}\n          // label=\"Username\"\n          // mode=\"flat\"\n          autoCapitalize=\"none\"\n          returnKeyType=\"next\"\n          value={username}\n          onChangeText={(text: string) => setUsername(text)}\n        />\n        <TextInput\n          style={{ width: 340 }}\n          // label=\"Password\"\n          // mode=\"flat\"\n          autoCapitalize=\"none\"\n          returnKeyType=\"done\"\n          value={password}\n          onChangeText={(text: string) => setPassword(text)}\n          secureTextEntry\n        />\n        {/* <HelperText type=\"error\" visible={error.length > 0}>\n          Error: {error}\n        </HelperText> */}\n        <Button\n          // mode=\"text\"\n          title=\"Sign up\"\n          onPress={async () => {\n            navigation.navigate('SignUp');\n          }}\n        />\n        {/* Sign up\n        </Button> */}\n        <Button\n          title=\"Sign In\"\n          // mode=\"contained\"\n          onPress={async () => {\n            if (username.length === 0 || password.length === 0) {\n              // setError('Username and password are required.');\n              console.log('bad');\n            } else {\n              try {\n                await Auth.signIn(username, password);\n                auth.setUser({ username: username });\n              } catch (e) {\n                console.error(e);\n                // setError(e.message);\n              }\n            }\n          }}\n        />\n        {/* Sign In\n        </Button> */}\n        {/* <Input />\n        <PrimaryButton\n          text=\"Sign in\"\n          onPress={async () => {\n            try {\n              await Auth.signIn('kgorges', 'Fourdowns!3058');\n              auth.setUser({ username: 'kgorges' });\n            } catch (e) {\n              console.error(e);\n            }\n          }}\n        />\n        <SecondaryButton\n          text=\"Sign up\"\n          onPress={async () => {\n            try {\n              await Auth.signIn('kgorges', 'Fourdowns!3058');\n              auth.setUser({ username: 'kgorges' });\n            } catch (e) {\n              console.error(e);\n            }\n          }}\n        /> */}\n      </View>\n    </>\n  );\n};\n\nconst styles = StyleSheet.create({\n  container: {\n    flex: 1,\n    alignItems: 'center',\n    justifyContent: 'center',\n    backgroundColor: 'white',\n  },\n});\n",{"ruleId":"59","replacedBy":"60"},{"ruleId":"61","repl